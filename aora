#!/usr/bin/env bash
# Vai para a pasta do projeto Aora antes de rodar, para achar o main.py e o .env
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
cd "$PROJECT_DIR" || exit

PYTHON="$PROJECT_DIR/.venv/bin/python3"
if [ ! -x "$PYTHON" ]; then
    PYTHON=python3
fi
"$PYTHON" main.py "$@"

